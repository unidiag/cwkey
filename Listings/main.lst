 638   1          /* I */
 639   1          for (i = 0; i < 2; i++) {
 640   2              send_startup_tone_dot();
 641   2          }
 642   1      
 643   1          tone_off();
 644   1          KEY_OUT = 0;
 645   1      
 646   1          delay_ms_blocking(300);
