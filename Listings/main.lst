  39          
  40          #define DEFAULT_WPM         20
  41          #define MIN_WPM             5
  42          #define MAX_WPM             35
  43          
  44          #define DEFAULT_TONE_HZ     1000
  45          #define MIN_TONE_HZ         0
  46          #define MAX_TONE_HZ         2500
