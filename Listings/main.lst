 564   1      
 565   1          if (dotRaw != dotLastRaw) {
 566   2              dotLastRaw = dotRaw;
 567   2              dotLastChangeMs = now;
 568   2          }
 569   1      
 570   1          if ((now - dotLastChangeMs) >= DEBOUNCE_MS) {
 571   2              dotStable = dotRaw;
 572   2          }
 573   1      
 574   1          if (dashRaw != dashLastRaw) {
 575   2              dashLastRaw = dashRaw;
 576   2              dashLastChangeMs = now;
 577   2          }
 578   1      
 579   1          if ((now - dashLastChangeMs) >= DEBOUNCE_MS) {
 580   2              dashStable = dashRaw;
 581   2          }
 582   1      
 583   1          if (downRaw != downLastRaw) {
 584   2              downLastRaw = downRaw;
 585   2              downLastChangeMs = now;
 586   2          }
 587   1      
 588   1          if ((now - downLastChangeMs) >= DEBOUNCE_MS) {
 589   2              downStable = downRaw;
 590   2          }
 591   1      
 592   1          if (upRaw != upLastRaw) {
 593   2              upLastRaw = upRaw;
 594   2              upLastChangeMs = now;
 595   2          }
 596   1      
 597   1          if ((now - upLastChangeMs) >= DEBOUNCE_MS) {
 598   2              upStable = upRaw;
 599   2          }
 600   1      }
