   1          #include <REG51.H>
   2          #include <intrins.h>
   3          
   4          /*
   5            STC15W204S CW keyer
   6            Keil C51
   7          
   8            Pin mapping:
   9              P5.5 -> DOT button, active LOW
  10              P5.4 -> DASH button, active LOW
  11              P3.3 -> KEY output + onboard LED
  12              P3.2 -> sidetone output to passive piezo / transistor speaker driver
  13          
  14              P3.0 -> DOWN button, active LOW
  15              P3.1 -> UP button, active LOW
  16          
  17            Normal mode:
  18              Short DOWN -> automatic message: CQ CQ DE EW6ML EW6ML EW6ML K
  19              Short UP   -> automatic message: 73!
  20          
  21              Long DOWN  -> speed DOWN
  22              Long UP    -> speed UP
  23          
  24            Tone adjustment:
  25              Hold DASH button P5.4 and press:
  26                P3.0 -> tone DOWN
  27                P3.1 -> tone UP
  28          */
  29          
  30          typedef unsigned char  u8;
  31          typedef unsigned int   u16;
  32          typedef unsigned long  u32;
  33          typedef signed char    s8;
  34          
  35          /*
  36            Set this to the clock frequency selected in STC-ISP.
  37          */
