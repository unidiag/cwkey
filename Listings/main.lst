 514          /* ---------- Pins ---------- */
 515          
 516          void pins_init(void) {
 517   1          /*
 518   1            P3.2 -> piezo output, push-pull
 519   1            P3.3 -> key output, push-pull
 520   1      
 521   1            P3.0 -> DOWN input
 522   1            P3.1 -> UP input
 523   1      
 524   1            P5.4 -> dash button input
 525   1            P5.5 -> dot button input
 526   1          */
 527   1      
 528   1          /* P3.2 and P3.3 push-pull outputs */
 529   1          P3M0 |= 0x0C;
 530   1          P3M1 &= ~0x0C;
 531   1      
 532   1          /*
 533   1            P3.0 and P3.1 as quasi-bidirectional inputs with weak pull-up.
 534   1          */
 535   1          P3M0 &= ~0x03;
 536   1          P3M1 &= ~0x03;
 537   1          P3 |= 0x03;
 538   1      
 539   1          /*
 540   1            P5.4 and P5.5 as quasi-bidirectional inputs with weak pull-up.
 541   1          */
 542   1          P5M0 &= ~0x30;
 543   1          P5M1 &= ~0x30;
 544   1          P5 |= 0x30;
 545   1      
 546   1          KEY_OUT = 0;
 547   1          PIEZO_OUT = 0;
 548   1      }
